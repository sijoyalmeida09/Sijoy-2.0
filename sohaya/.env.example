# ============================================================
# SOHALA — Environment Variables
# Copy to .env.local for local dev.
# Add ALL of these in Vercel Dashboard → Project Settings → Environment Variables
# ============================================================

# --- Supabase (NEW dedicated project — NOT shared with josho-hub) ---
# Create at: https://supabase.com/dashboard → New Project → "sohala"
# After creating: Settings → API → copy URL + anon key + service_role key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cookie domain — use "localhost" for dev, ".joshoit.com" for Vercel prod
SUPABASE_COOKIE_DOMAIN=localhost

# --- AI: Groq (FREE — primary LLM) ---
# 14,400 req/day free. Get from: https://console.groq.com/keys
GROQ_API_KEY=

# --- AI: Anthropic / Claude (optional upgrade path) ---
# Claude Pro account: sijoyalmeida@gmail.com → https://console.anthropic.com
# Leave blank to use Groq for everything
ANTHROPIC_API_KEY=

# --- Payments: UPI (personal UPI — currently active) ---
# Amount is auto-embedded in QR. No Razorpay needed for this flow.
NEXT_PUBLIC_UPI_ID=sijoyalmeida-1@oksbi
NEXT_PUBLIC_UPI_NAME=Sohala

# --- Payments: Razorpay (future — leave blank for now) ---
# Get real test keys from: https://dashboard.razorpay.com/app/keys
# Payout (Razorpay X): https://x.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# --- Email: Resend ---
# Get from: https://resend.com/api-keys
# Domain hello@joshoit.com already configured in josho-hub — can reuse
RESEND_API_KEY=
WELCOME_EMAIL_FROM=Sohala <hello@joshoit.com>

# --- WhatsApp: Msg91 ---
# Get from: https://msg91.com/
MSG91_API_KEY=
MSG91_SENDER_ID=SOHALA

# --- Google Maps (Go Live GPS + location autocomplete) ---
# Get from: https://console.cloud.google.com/ → APIs → Maps JavaScript API
GOOGLE_MAPS_API_KEY=

# --- App Config ---
# Local dev: http://localhost:3000
# Vercel prod: https://sohala.joshoit.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
